{
  "name": "inkwell",
  "version": "0.1.0",
  "description": "A modern, cross-platform PDF reader & editor with agentic AI side panel",
  "main": "dist-electron/main.js",
  "author": "Inkwell Contributors",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build:electron",
    "build:electron": "tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:preview": "npm run build && electron .",
    "backend:install": "cd backend && pip install -e .",
    "backend:dev": "cd backend && /usr/bin/python3 -m inkwell.server"
  },
  "dependencies": {
    "@agentclientprotocol/claude-agent-acp": "^0.55.0",
    "@agentclientprotocol/codex-acp": "^1.1.0",
    "@mcpc-tech/acp-ai-provider": "^0.3.3",
    "ai": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf-highlighter-plus": "^1.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "electron": "^33.2.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
